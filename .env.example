# ========================================
# Variáveis de Ambiente - VinculoHubPortal
# ========================================
# Copie este arquivo para .env e preencha com seus valores.
# Comando: cp .env.example .env

# ---- Banco de Dados (PostgreSQL) ----
POSTGRES_USER=vinculohub
POSTGRES_PASSWORD=vinculohub
POSTGRES_DB=vinculohub_db

# ---- Backend / Frontend ----
BACKEND_PORT=8080
FRONTEND_URL=http://localhost:5173

# ---- Auth0 ----
AUTH0_DOMAIN=your-tenant.us.auth0.com
AUTH0_AUDIENCE=https://api.vinculohub
AUTH0_ISSUER_URI=https://your-tenant.us.auth0.com/
AUTH0_ROLES_CLAIM=https://vinculohub/roles
