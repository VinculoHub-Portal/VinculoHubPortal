# ========================================
# Variáveis de Ambiente - VinculoHubPortal
# ========================================
# Copie este arquivo para .env e preencha com seus valores.
# Comando: cp .env.example .env

# ---- Banco de Dados (PostgreSQL) ----
POSTGRES_USER=vinculohub
POSTGRES_PASSWORD=vinculohub
POSTGRES_DB=vinculohub_db

# ---- Backend / Frontend ----
BACKEND_PORT=8080
FRONTEND_URL=http://localhost:5173, http://localhost

# ---- Auth0 ----
AUTH0_DOMAIN=your-tenant.us.auth0.com
AUTH0_AUDIENCE=https://api.vinculohub
AUTH0_ISSUER_URI=https://your-tenant.us.auth0.com/
AUTH0_ROLES_CLAIM=https://vinculohub/roles
VITE_API_URL=http://localhost:8080
VITE_AUTH0_DOMAIN=your-tenant.us.auth0.com
VITE_AUTH0_CLIENT_ID=your-auth0-spa-client-id
VITE_AUTH0_AUDIENCE=https://api.vinculohub

# ---- Sample data seed (optional, disabled by default) ----
APP_SAMPLE_DATA_ENABLED=false
APP_SAMPLE_DATA_DATASET_ID=default
APP_SAMPLE_DATA_HOST_PATH=./backend/src/main/resources/db/sample-data/default
APP_SAMPLE_DATA_LOCATION=file:/sample-data
APP_SAMPLE_DATA_AUTH0_DOMAIN=your-tenant.us.auth0.com
APP_SAMPLE_DATA_AUTH0_CLIENT_ID=your-auth0-management-m2m-client-id
APP_SAMPLE_DATA_AUTH0_CLIENT_SECRET=your-auth0-management-m2m-client-secret
