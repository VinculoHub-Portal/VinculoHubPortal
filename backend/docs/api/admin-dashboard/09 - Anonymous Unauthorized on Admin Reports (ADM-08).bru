meta {
  name: 09 - Anonymous Unauthorized on Admin Reports (ADM-08)
  type: http
  seq: 9
}

get {
  url: {{baseUrl}}/api/admin/npo-reports
  body: none
}

script:post-response {
  if (res.getStatus() !== 401) {
    throw new Error(`Esperado 401 sem token em rota ADMIN, recebido ${res.getStatus()}`)
  }
}

docs {
  Confirma que a rota administrativa exige autenticação.
}
