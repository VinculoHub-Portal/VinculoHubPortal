meta {
  name: 10 - NPO Forbidden on Admin Reports (ADM-09)
  type: http
  seq: 10
}

get {
  url: {{baseUrl}}/api/admin/npo-reports
  body: none
  auth: bearer
}

auth:bearer {
  token: {{npoToken}}
}

script:post-response {
  if (res.getStatus() !== 403) {
    throw new Error(`Esperado 403 para NPO em rota ADMIN, recebido ${res.getStatus()}`)
  }
}

docs {
  Confirma que uma ONG autenticada também não consegue acessar a listagem administrativa de denúncias.
}
