meta {
  name: 08 - Company Forbidden on Admin Reports (ADM-07)
  type: http
  seq: 8
}

get {
  url: {{baseUrl}}/api/admin/npo-reports
  body: none
  auth: bearer
}

auth:bearer {
  token: {{companyToken}}
}

script:post-response {
  if (res.getStatus() !== 403) {
    throw new Error(`Esperado 403 para COMPANY em rota ADMIN, recebido ${res.getStatus()}`)
  }
}

docs {
  Confirma que uma empresa autenticada não consegue acessar a listagem administrativa de denúncias.
}
