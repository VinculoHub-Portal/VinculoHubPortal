meta {
  name: 05 - NPO Forbidden on Company Showcase (CMP-04)
  type: http
  seq: 5
}

get {
  url: {{baseUrl}}/api/company/npos
  body: none
  auth: bearer
}

auth:bearer {
  token: {{npoToken}}
}

script:post-response {
  if (res.getStatus() !== 403) {
    throw new Error(`Esperado 403 para NPO na vitrine da empresa, recebido ${res.getStatus()}`)
  }
}

docs {
  Confirma que uma ONG autenticada não consegue acessar a listagem exclusiva da empresa.
}
