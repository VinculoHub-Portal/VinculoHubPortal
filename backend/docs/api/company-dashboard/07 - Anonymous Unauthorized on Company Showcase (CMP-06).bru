meta {
  name: 07 - Anonymous Unauthorized on Company Showcase (CMP-06)
  type: http
  seq: 7
}

get {
  url: {{baseUrl}}/api/company/npos
  body: none
}

script:post-response {
  if (res.getStatus() !== 401) {
    throw new Error(`Esperado 401 sem token na vitrine da empresa, recebido ${res.getStatus()}`)
  }
}

docs {
  Confirma que a rota da vitrine da empresa exige autenticação.
}
